{
  "$defs": {
    "ArtifactIntegrityLink": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_type": {
          "minLength": 1,
          "title": "Artifact Type",
          "type": "string"
        },
        "previous_sha256": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Previous Sha256"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "artifact_id",
        "sha256"
      ],
      "title": "ArtifactIntegrityLink",
      "type": "object"
    },
    "CapabilityPatchSet": {
      "additionalProperties": false,
      "properties": {
        "context": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Context",
          "type": "array"
        },
        "harness": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Harness",
          "type": "array"
        },
        "prompt": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Prompt",
          "type": "array"
        }
      },
      "title": "CapabilityPatchSet",
      "type": "object"
    },
    "CapabilityStatus": {
      "enum": [
        "candidate",
        "validated",
        "stable",
        "deprecated"
      ],
      "type": "string"
    },
    "CommandRiskCategory": {
      "enum": [
        "write",
        "destructive",
        "external_call",
        "credential_access",
        "production_write",
        "paid_operation"
      ],
      "type": "string"
    },
    "ContextPolicy": {
      "additionalProperties": false,
      "properties": {
        "compression_rule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compression Rule"
        },
        "evidence_recall_strategy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Recall Strategy"
        },
        "forbidden": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Forbidden",
          "type": "array"
        },
        "freshness_rule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Freshness Rule"
        },
        "maximum_token_budget": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Token Budget"
        },
        "optional": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Optional",
          "type": "array"
        },
        "required": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Required",
          "type": "array"
        },
        "retrieval_query_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retrieval Query Template"
        },
        "source_priority": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Source Priority",
          "type": "array"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ContextSource"
          },
          "title": "Sources",
          "type": "array"
        },
        "summarization_rule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summarization Rule"
        }
      },
      "title": "ContextPolicy",
      "type": "object"
    },
    "ContextSource": {
      "additionalProperties": false,
      "properties": {
        "freshness": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Freshness"
        },
        "location": {
          "minLength": 1,
          "title": "Location",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "priority": {
          "default": 100,
          "minimum": 0,
          "title": "Priority",
          "type": "integer"
        },
        "type": {
          "$ref": "#/$defs/ContextSourceType"
        }
      },
      "required": [
        "name",
        "type",
        "location"
      ],
      "title": "ContextSource",
      "type": "object"
    },
    "ContextSourceType": {
      "enum": [
        "repo",
        "docs",
        "logs",
        "evidence",
        "review",
        "preference"
      ],
      "type": "string"
    },
    "EvidencePolicy": {
      "additionalProperties": false,
      "properties": {
        "store": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Store",
          "type": "array"
        }
      },
      "title": "EvidencePolicy",
      "type": "object"
    },
    "FieldFailureHistory": {
      "additionalProperties": false,
      "properties": {
        "cases": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Cases",
          "type": "array"
        },
        "recall_strategy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recall Strategy"
        }
      },
      "title": "FieldFailureHistory",
      "type": "object"
    },
    "FieldManifest": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "failure_history": {
          "$ref": "#/$defs/FieldFailureHistory"
        },
        "name": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "policies": {
          "$ref": "#/$defs/FieldPolicy"
        },
        "preferences": {
          "default": [],
          "items": {
            "$ref": "#/$defs/FieldPreference"
          },
          "title": "Preferences",
          "type": "array"
        },
        "quality_bar": {
          "$ref": "#/$defs/FieldQualityBar"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ContextSource"
          },
          "title": "Sources",
          "type": "array"
        }
      },
      "required": [
        "name",
        "description"
      ],
      "title": "FieldManifest",
      "type": "object"
    },
    "FieldPolicy": {
      "additionalProperties": false,
      "properties": {
        "forbidden_context": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Forbidden Context",
          "type": "array"
        },
        "network": {
          "$ref": "#/$defs/NetworkPolicy",
          "default": "disabled"
        },
        "require_approval": {
          "default": [
            "write",
            "destructive",
            "external_call",
            "credential_access",
            "production_write",
            "paid_operation"
          ],
          "items": {
            "$ref": "#/$defs/CommandRiskCategory"
          },
          "title": "Require Approval",
          "type": "array"
        }
      },
      "title": "FieldPolicy",
      "type": "object"
    },
    "FieldPreference": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "minLength": 1,
          "title": "Key",
          "type": "string"
        },
        "value": {
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ],
      "title": "FieldPreference",
      "type": "object"
    },
    "FieldQualityBar": {
      "additionalProperties": false,
      "properties": {
        "human_review_required": {
          "default": true,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "required_checks": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Required Checks",
          "type": "array"
        }
      },
      "title": "FieldQualityBar",
      "type": "object"
    },
    "HarnessResult": {
      "additionalProperties": false,
      "properties": {
        "checks": {
          "items": {
            "type": "string"
          },
          "title": "Checks",
          "type": "array"
        },
        "failures": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Failures",
          "type": "array"
        },
        "human_review_required": {
          "default": false,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "required_checks": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Required Checks",
          "type": "array"
        },
        "schema_version": {
          "default": "omf.harness.v0.1",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/HarnessStatus"
        }
      },
      "required": [
        "status",
        "checks"
      ],
      "title": "HarnessResult",
      "type": "object"
    },
    "HarnessStatus": {
      "enum": [
        "pass",
        "fail"
      ],
      "type": "string"
    },
    "HumanReview": {
      "additionalProperties": false,
      "properties": {
        "added_context": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Added Context",
          "type": "array"
        },
        "changed_constraint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Changed Constraint"
        },
        "changed_goal": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Changed Goal"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "regression_case": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Regression Case"
        },
        "reusable": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reusable"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed At"
        },
        "reviewer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewer"
        },
        "revision_request": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revision Request"
        },
        "status": {
          "$ref": "#/$defs/HumanReviewStatus",
          "default": "pending"
        },
        "unsafe": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unsafe"
        }
      },
      "title": "HumanReview",
      "type": "object"
    },
    "HumanReviewStatus": {
      "enum": [
        "pending",
        "approved",
        "rejected",
        "revision_requested",
        "context_added",
        "goal_changed",
        "constraint_changed",
        "marked_reusable",
        "marked_unsafe",
        "regression_case_created"
      ],
      "type": "string"
    },
    "NetworkPolicy": {
      "enum": [
        "disabled",
        "internal_only",
        "allowed"
      ],
      "type": "string"
    },
    "PromotionCriteria": {
      "additionalProperties": false,
      "properties": {
        "max_human_intervention_rate": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Max Human Intervention Rate",
          "type": "number"
        },
        "min_runtime_profiles": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Min Runtime Profiles",
          "type": "array"
        },
        "min_success_runs": {
          "minimum": 1,
          "title": "Min Success Runs",
          "type": "integer"
        },
        "required_harness_pass_rate": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Required Harness Pass Rate",
          "type": "number"
        }
      },
      "required": [
        "min_success_runs",
        "max_human_intervention_rate",
        "required_harness_pass_rate"
      ],
      "title": "PromotionCriteria",
      "type": "object"
    },
    "PromotionMetrics": {
      "additionalProperties": false,
      "properties": {
        "criteria_met": {
          "default": false,
          "title": "Criteria Met",
          "type": "boolean"
        },
        "eval_count": {
          "default": 0,
          "minimum": 0,
          "title": "Eval Count",
          "type": "integer"
        },
        "eval_gate_met": {
          "default": true,
          "title": "Eval Gate Met",
          "type": "boolean"
        },
        "eval_pass_rate": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Eval Pass Rate",
          "type": "number"
        },
        "evidence_count": {
          "minimum": 0,
          "title": "Evidence Count",
          "type": "integer"
        },
        "failed_evidence_count": {
          "minimum": 0,
          "title": "Failed Evidence Count",
          "type": "integer"
        },
        "harness_pass_rate": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Harness Pass Rate",
          "type": "number"
        },
        "human_intervention_rate": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Human Intervention Rate",
          "type": "number"
        },
        "recommended_version_bump": {
          "default": "patch",
          "title": "Recommended Version Bump",
          "type": "string"
        },
        "retry_rate": {
          "minimum": 0.0,
          "title": "Retry Rate",
          "type": "number"
        },
        "runtime_profiles": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Runtime Profiles",
          "type": "array"
        },
        "successful_evidence_count": {
          "minimum": 0,
          "title": "Successful Evidence Count",
          "type": "integer"
        }
      },
      "required": [
        "evidence_count",
        "successful_evidence_count",
        "failed_evidence_count",
        "harness_pass_rate",
        "human_intervention_rate",
        "retry_rate"
      ],
      "title": "PromotionMetrics",
      "type": "object"
    },
    "RuntimeInfo": {
      "additionalProperties": false,
      "properties": {
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "preferred_models": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Preferred Models",
          "type": "array"
        },
        "tools": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "RuntimeInfo",
      "type": "object"
    },
    "WorkflowControl": {
      "additionalProperties": false,
      "properties": {
        "allowed_tools": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Allowed Tools",
          "type": "array"
        },
        "approval_required_actions": {
          "default": [
            "write",
            "destructive",
            "external_call",
            "credential_access",
            "production_write",
            "paid_operation"
          ],
          "items": {
            "$ref": "#/$defs/CommandRiskCategory"
          },
          "title": "Approval Required Actions",
          "type": "array"
        },
        "checkpoint_interval": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checkpoint Interval"
        },
        "credential_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Credential Scope"
        },
        "disallowed_tools": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Disallowed Tools",
          "type": "array"
        },
        "max_cost_usd": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Cost Usd"
        },
        "max_iterations": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Iterations"
        },
        "max_runtime_seconds": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Runtime Seconds"
        },
        "network_policy": {
          "$ref": "#/$defs/NetworkPolicy",
          "default": "disabled"
        },
        "require_approval_before_destructive_action": {
          "default": true,
          "title": "Require Approval Before Destructive Action",
          "type": "boolean"
        },
        "require_approval_before_external_call": {
          "default": true,
          "title": "Require Approval Before External Call",
          "type": "boolean"
        },
        "require_approval_before_write": {
          "default": true,
          "title": "Require Approval Before Write",
          "type": "boolean"
        },
        "resume_from_checkpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resume From Checkpoint"
        },
        "rollback_policy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rollback Policy"
        },
        "rollback_strategy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rollback Strategy"
        },
        "safe_execution_mode": {
          "default": true,
          "title": "Safe Execution Mode",
          "type": "boolean"
        }
      },
      "title": "WorkflowControl",
      "type": "object"
    },
    "WorkflowGraph": {
      "const": "langgraph",
      "type": "string"
    },
    "WorkflowManifest": {
      "additionalProperties": false,
      "properties": {
        "graph": {
          "$ref": "#/$defs/WorkflowGraph"
        },
        "nodes": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Nodes",
          "type": "array"
        }
      },
      "required": [
        "graph",
        "nodes"
      ],
      "title": "WorkflowManifest",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "context": {
      "$ref": "#/$defs/ContextPolicy"
    },
    "dependencies": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Dependencies",
      "type": "array"
    },
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "evaluation_results": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Evaluation Results",
      "type": "array"
    },
    "evidence": {
      "$ref": "#/$defs/EvidencePolicy"
    },
    "field": {
      "anyOf": [
        {
          "$ref": "#/$defs/FieldManifest"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "harness": {
      "$ref": "#/$defs/HarnessResult"
    },
    "human_review": {
      "$ref": "#/$defs/HumanReview"
    },
    "inputs": {
      "items": {
        "type": "string"
      },
      "title": "Inputs",
      "type": "array"
    },
    "integrity_chain": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactIntegrityLink"
      },
      "title": "Integrity Chain",
      "type": "array"
    },
    "name": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "title": "Name",
      "type": "string"
    },
    "normalized_goal": {
      "minLength": 1,
      "title": "Normalized Goal",
      "type": "string"
    },
    "owner": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Owner"
    },
    "patches": {
      "$ref": "#/$defs/CapabilityPatchSet"
    },
    "promotion_criteria": {
      "$ref": "#/$defs/PromotionCriteria"
    },
    "promotion_metrics": {
      "anyOf": [
        {
          "$ref": "#/$defs/PromotionMetrics"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeInfo"
    },
    "runtime_compatibility": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Runtime Compatibility",
      "type": "array"
